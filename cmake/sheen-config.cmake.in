@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(slot CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/sheen-core-targets.cmake")

set(_sheen_supported_components yaml json)

foreach(_comp ${sheen_FIND_COMPONENTS})
    if(NOT _comp IN_LIST _sheen_supported_components)
        set(sheen_FOUND False)
        set(sheen_NOT_FOUND_MESSAGE "Unsupported sheen component: ${_comp}")
        return()
    endif()
    include("${CMAKE_CURRENT_LIST_DIR}/sheen-${_comp}-targets.cmake")
endforeach()

check_required_components(sheen)
